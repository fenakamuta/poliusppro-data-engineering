# Modelo de configuração do Supabase.
#
# 1. Copie este arquivo para  .streamlit/secrets.toml  (sem o .example)
# 2. Preencha com os dados do seu projeto Supabase:
#    Project Settings -> API -> "Project URL" e "anon public" key
# 3. NÃO comite o secrets.toml (já está no .gitignore)
#
# No Streamlit Community Cloud, cole estes valores em
#   App -> Settings -> Secrets  (mesmo formato).

[supabase]
url = "https://SEU-PROJETO.supabase.co"
key = "sua-anon-public-key-aqui"
